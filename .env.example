## Web (Vite) / Mobile (Expo)
# Supabase (copy from your project settings)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Groq (optional) – used for the in-app AI assistant (ArchBot)
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY

## Server-side scripts (never expose this in client apps)
# Used by `scripts/seed-teams.mjs` and any future admin scripts.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
